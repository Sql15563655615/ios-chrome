+# Chromium 72 removed production iOS ARMv7 support upstream. This port restores
+# ARMv7 as an explicitly supported feasibility target for iOS 9.3 devices.
+ios_enable_armv7 = target_cpu == "arm" && ios_deployment_target == "9.3"
+
